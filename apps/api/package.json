{
  "name": "@kraftplan/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Unified KraftPlan API — all services combined into one deployable (free-tier friendly).",
  "scripts": {
    "dev": "tsx watch src/index.ts",
