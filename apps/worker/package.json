{
  "name": "@kraftplan/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "KraftPlan API on Cloudflare Workers — always-on, zero cold start, Neon over HTTP.",
  "scripts": {
    "predev": "pnpm --filter @kraftplan/shared build",
    "dev": "wrangler dev --port 4001",
    "predeploy": "pnpm --filter @kraftplan/shared build",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@kraftplan/shared": "workspace:*",
    "@neondatabase/serverless": "^0.9.4",
    "drizzle-orm": "^0.31.0",
    "hono": "^4.6.0",
    "jose": "^5.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.90.0"
  }
}
