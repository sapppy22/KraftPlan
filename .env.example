LIBRARY_PORT=4005

# ── Frontend ──
NEXT_PUBLIC_API_BASE=http://localhost:4001

# ── Auth ──
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
