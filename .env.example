# ── Database (Neon) ──
# Pooled connection string (host contains "-pooler") for the app runtime.
DATABASE_URL=postgres://kraftplan:kraftplan@localhost:5432/kraftplan
# Direct (non-pooled) connection string for drizzle-kit schema push/migrations.
DATABASE_URL_UNPOOLED=postgres://kraftplan:kraftplan@localhost:5432/kraftplan

# ── Redis (optional; not required to run) ──
REDIS_URL=redis://localhost:6379

# ── JWT ──
JWT_SECRET=change-this-to-a-random-secret-in-production

# ── Unified API server (apps/api) ──
API_PORT=4001
# Comma-separated allowed origins in production (e.g. https://kraftplan.pages.dev)
CORS_ORIGIN=

# ── Frontend ──
NEXT_PUBLIC_API_BASE=http://localhost:4001

# ── Cloudflare (deploy) ──
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PAGES_PROJECT=kraftplan

# ── Object storage (Cloudflare R2, optional) ──
S3_ENDPOINT=
S3_BUCKET=kraftplan-media
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Optional integrations ──
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
