{
  "name": "kraftplan",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev --concurrency 16",
    "dev:local": "turbo dev --filter=@kraftplan/worker --filter=@kraftplan/web --concurrency 16",
    "dev:web": "pnpm --filter @kraftplan/web dev",
    "dev:api": "pnpm --filter @kraftplan/api dev",
    "start:api": "pnpm --filter @kraftplan/api start",
    "build": "turbo build",
    "build:web": "pnpm --filter @kraftplan/web build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "db:push": "pnpm --filter @kraftplan/db push",
    "db:generate": "pnpm --filter @kraftplan/db generate",
    "db:migrate": "pnpm --filter @kraftplan/db migrate",
    "db:seed": "pnpm --filter @kraftplan/db seed",
    "db:studio": "pnpm --filter @kraftplan/db studio",
    "deploy:pinger": "pnpm --filter @kraftplan/pinger deploy",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\""
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
